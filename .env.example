# ──────────────────────────────────────────────────────────────
# ASBA Environment Configuration
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────────────────

# Google Gemini API Configuration (Standard API Key)
GOOGLE_API_KEY=your_api_key_here

# Google Cloud Vertex AI Configuration (Set to true to use Vertex AI instead of standard API)
USE_VERTEX_AI=false
GCP_PROJECT=your_project_id_here

# Google Cloud Storage (GCS) Backup Configuration (For serverless persistence)
USE_GCS=false
GCS_BUCKET=your_bucket_name_here

# Express Server Port Configuration
PORT=5000
